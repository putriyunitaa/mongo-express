<!DOCTYPE html>
<html>
<head>
  <title>Data Dosen</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Daftar Dosen</h1>
    <button class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#formTambah">+ Tambah Dosen</button>
  </div>

  <table class="table table-bordered">
    <thead class="table-light">
      <tr><th>NIP</th><th>Nama</th><th>Mengajar</th><th>Aksi</th></tr>
    </thead>
    <tbody>
      <% dosen.forEach(d => { %>
        <tr>
          <td><%= d.nip %></td>
          <td><%= d.nama %></td>
          <td>
            <ul>
              <% d.mengajar.forEach(mk => { %>
                <li><%= mk.nama %></li>
              <% }) %>
            </ul>
          </td>
          <td>
            <button class="btn btn-sm btn-warning" data-bs-toggle="collapse" data-bs-target="#editForm<%= d._id %>">Edit</button>
            <a href="/dosen/delete/<%= d._id %>" class="btn btn-sm btn-danger">Delete</a>
          </td>
        </tr>
        <tr class="collapse" id="editForm<%= d._id %>">
          <td colspan="4">
            <form action="/dosen/update/<%= d._id %>" method="POST" class="row g-2">
              <div class="col-md-4"><input type="text" name="nip" value="<%= d.nip %>" class="form-control" /></div>
              <div class="col-md-4"><input type="text" name="nama" value="<%= d.nama %>" class="form-control" /></div>
              <div class="col-md-4"><button type="submit" class="btn btn-success">Update</button></div>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="collapse" id="formTambah">
    <div class="card card-body">
      <form action="/dosen" method="POST" class="row g-2">
        <div class="col-md-4"><input type="text" name="nip" placeholder="NIP" required class="form-control" /></div>
        <div class="col-md-4"><input type="text" name="nama" placeholder="Nama" required class="form-control" /></div>
        <div class="col-md-4"><button type="submit" class="btn btn-primary">Tambah</button></div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
