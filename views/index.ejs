<!DOCTYPE html>
<html>
<head>
  <title>Dashboard CRUD</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light p-5">

  <div class="container">
    <div class="text-center mb-5">
      <h1 class="fw-bold text-success">📊 Dashboard CRUD</h1>
      <p class="text-muted">Kelola data Mahasiswa, Dosen, dan Mata Kuliah dengan mudah</p>
    </div>

    <div class="row g-4">
      <!-- Card Mahasiswa -->
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body text-center">
            <h3 class="card-title text-primary">👩‍🎓 Mahasiswa</h3>
            <p class="card-text">Lihat, tambah, edit, dan hapus data mahasiswa.</p>
            <a href="/mahasiswa" class="btn btn-outline-primary">Kelola Mahasiswa</a>
          </div>
        </div>
      </div>

      <!-- Card Dosen -->
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body text-center">
            <h3 class="card-title text-warning">👨‍🏫 Dosen</h3>
            <p class="card-text">Kelola data dosen beserta mata kuliah yang diajar.</p>
            <a href="/dosen" class="btn btn-outline-warning">Kelola Dosen</a>
          </div>
        </div>
      </div>

      <!-- Card Mata Kuliah -->
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body text-center">
            <h3 class="card-title text-success">📚 Mata Kuliah</h3>
            <p class="card-text">Atur daftar mata kuliah dan dosen pengampu.</p>
            <a href="/matakuliah" class="btn btn-outline-success">Kelola Mata Kuliah</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
